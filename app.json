{
  "expo": {
    "name": "Hisab",
    "slug": "hisab",
    "version": "10.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hisab",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F5F9"
    },
    "backgroundColor": "#F3F5F9",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hisab.app",
      "buildNumber": "30"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3F5F9",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.hisab.app",
      "versionCode": 30,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3F5F9",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0B0D10",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-system-ui",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
