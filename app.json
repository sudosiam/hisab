{
  "expo": {
    "name": "Hisab",
    "slug": "hisab",
    "version": "3.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hisab",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F5F9"
    },
    "backgroundColor": "#F3F5F9",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hisab.app",
      "buildNumber": "6"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3F5F9",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.hisab.app",
      "versionCode": 5,
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3F5F9",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0B0D10",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-system-ui",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hisab to attach sale and purchase photos from your gallery.",
          "cameraPermission": "Allow Hisab to take photos of bills and receipts."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Hisab to save attachment photos to your gallery.",
          "savePhotosPermission": "Allow Hisab to save attachment photos to your gallery."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Hisab to use Face ID to unlock your business data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
